#include <windows.h>

#define IDI_APP 101

IDI_APP ICON "bliss_chat.ico"

// Toolbar icon strip — 5 icons x 24x24, magenta = transparency key.
#define IDB_TOOLBAR 102
IDB_TOOLBAR BITMAP "toolbar_icons.bmp"

// Comctl32 v6 manifest — opts the process into the XP "Luna" theme so
// the progress bar gets the green segmented look (and buttons / edits
// pick up theming too) instead of the classic Win9x chrome.
1 RT_MANIFEST "xpchat.manifest"

// ----- Settings dialog -----
#define IDD_SETTINGS         200
#define IDC_TEMP_EDIT        201
#define IDC_SEED_EDIT        202
#define IDC_SEED_RANDOM      203
#define IDC_PRESET_GREEDY    204
#define IDC_PRESET_BALANCED  205
#define IDC_PRESET_CREATIVE  206
#define IDC_DEFAULTS         207
#define IDC_TOPP_EDIT        214
#define IDC_MAXTOK_EDIT      215
#define IDC_SYSPROMPT_EDIT   216
#define IDC_RESET_ALL        217

// ----- Rename Chat dialog -----
#define IDD_RENAME           210
#define IDC_RENAME_EDIT      211

// ----- Edit-prompt dialog -----
#define IDD_EDITPROMPT       212
#define IDC_EDITPROMPT_TEXT  213

// ----- Find dialog -----
#define IDD_FIND             220
#define IDC_FIND_EDIT        221
#define IDC_FIND_NEXT        222

// ----- Keyboard Shortcuts dialog -----
#define IDD_SHORTCUTS        230
#define IDC_SHORTCUTS_TEXT   231

IDD_SETTINGS DIALOGEX 0, 0, 260, 280
CAPTION "Bliss Chat - Settings"
FONT 8, "MS Shell Dlg"
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
BEGIN
    GROUPBOX   "Sampling",                                  -1,  8,   4, 244, 112

    LTEXT      "Temperature:",                              -1, 16,  18,  60, 10
    EDITTEXT                              IDC_TEMP_EDIT,        80, 16,  40, 12, ES_AUTOHSCROLL
    LTEXT      "0 = greedy, higher = more random",         -1, 128, 18, 116, 10

    LTEXT      "Seed:",                                     -1, 16,  34,  60, 10
    EDITTEXT                              IDC_SEED_EDIT,        80, 32,  80, 12, ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON "Random",                  IDC_SEED_RANDOM,     165, 32,  50, 14

    LTEXT      "Presets:",                                  -1, 16,  52,  60, 10
    PUSHBUTTON "Greedy (t=0)",            IDC_PRESET_GREEDY,    16, 64,  65, 14
    PUSHBUTTON "Balanced (t=0.7)",        IDC_PRESET_BALANCED,  86, 64,  75, 14
    PUSHBUTTON "Creative (t=1.2)",        IDC_PRESET_CREATIVE, 166, 64,  78, 14
    LTEXT      "Greedy is fully deterministic; Balanced and Creative add variety.",
                                                            -1, 16,  84, 230, 10
    PUSHBUTTON "Reset Defaults",          IDC_DEFAULTS,        16,  98, 80, 14

    GROUPBOX   "Advanced",                                  -1,  8, 120, 244, 130

    LTEXT      "Top-P:",                                    -1, 16, 134,  60, 10
    EDITTEXT                              IDC_TOPP_EDIT,        80, 132,  40, 12, ES_AUTOHSCROLL
    LTEXT      "0..1, default 0.95",                        -1, 128, 134, 116, 10

    LTEXT      "Max tokens:",                               -1, 16, 152,  60, 10
    EDITTEXT                              IDC_MAXTOK_EDIT,      80, 150,  40, 12, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT      "1..2048, 0 = no cap",                       -1, 128, 152, 116, 10

    LTEXT      "System prompt:",                            -1, 16, 170,  80, 10
    EDITTEXT                              IDC_SYSPROMPT_EDIT,   16, 182, 228, 48,
                                                                ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    PUSHBUTTON "Reset All Settings",      IDC_RESET_ALL,       16, 232, 110, 14

    DEFPUSHBUTTON "OK",                   IDOK,               145, 256,  50, 18
    PUSHBUTTON    "Cancel",               IDCANCEL,           199, 256,  50, 18
END

IDD_FIND DIALOGEX 0, 0, 220, 56
CAPTION "Find"
FONT 8, "MS Shell Dlg"
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
BEGIN
    LTEXT         "Find what:",                -1,             8,  10,  40,  10
    EDITTEXT                                   IDC_FIND_EDIT,  50,  8, 160,  12, ES_AUTOHSCROLL
    DEFPUSHBUTTON "Find Next",                 IDC_FIND_NEXT,  50, 30,  60,  16
    PUSHBUTTON    "Close",                     IDCANCEL,      150, 30,  60,  16
END

IDD_SHORTCUTS DIALOGEX 0, 0, 250, 180
CAPTION "Keyboard Shortcuts"
FONT 8, "MS Shell Dlg"
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
BEGIN
    EDITTEXT                                   IDC_SHORTCUTS_TEXT, 8, 8, 234, 144,
                                                ES_MULTILINE | ES_READONLY | WS_VSCROLL
    DEFPUSHBUTTON "OK",                        IDOK,              190, 158, 52, 16
END

IDD_RENAME DIALOGEX 0, 0, 240, 62
CAPTION "Rename Chat"
FONT 8, "MS Shell Dlg"
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
BEGIN
    LTEXT      "Chat title:",                                 -1, 12,  10, 60, 10
    EDITTEXT                              IDC_RENAME_EDIT,        12, 22, 216, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON "OK",                   IDOK,                  130, 42, 45, 14
    PUSHBUTTON    "Cancel",               IDCANCEL,              183, 42, 45, 14
END

IDD_EDITPROMPT DIALOGEX 0, 0, 320, 180
CAPTION "Bliss Chat - Edit last prompt"
FONT 8, "MS Shell Dlg"
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
BEGIN
    LTEXT      "Edit your last message and click Resend. The backend's prior turn will be dropped from KV cache.",
                                          -1,                  10,  8, 300, 18
    EDITTEXT                              IDC_EDITPROMPT_TEXT, 10, 28, 300, 124,
               ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL
    DEFPUSHBUTTON "Resend",               IDOK,               200, 158, 50, 16
    PUSHBUTTON    "Cancel",               IDCANCEL,           260, 158, 50, 16
END

1 VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x00040004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "Bliss Chat"
      VALUE "FileDescription", "Bliss Chat — XP-native LLM"
      VALUE "FileVersion", "1.0.0"
      VALUE "InternalName", "XPCHAT"
      VALUE "OriginalFilename", "XPCHAT.EXE"
      VALUE "ProductName", "Bliss Chat"
      VALUE "ProductVersion", "1.0.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
