#include <windows.h>

#define IDI_APP 101

IDI_APP ICON "bliss_chat.ico"

// Comctl32 v6 manifest — opts the process into the XP "Luna" theme so
// the progress bar gets the green segmented look (and buttons / edits
// pick up theming too) instead of the classic Win9x chrome.
1 RT_MANIFEST "xpchat.manifest"

// ----- Settings dialog -----
#define IDD_SETTINGS         200
#define IDC_TEMP_EDIT        201
#define IDC_SEED_EDIT        202
#define IDC_SEED_RANDOM      203
#define IDC_PRESET_GREEDY    204
#define IDC_PRESET_BALANCED  205
#define IDC_PRESET_CREATIVE  206
#define IDC_DEFAULTS         207

// ----- Rename Chat dialog -----
#define IDD_RENAME           210
#define IDC_RENAME_EDIT      211

IDD_SETTINGS DIALOGEX 0, 0, 240, 160
CAPTION "bliss-chat - Settings"
FONT 8, "MS Shell Dlg"
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
BEGIN
    LTEXT      "Temperature:",                              -1, 12,  14, 60, 10
    EDITTEXT                              IDC_TEMP_EDIT,        80, 12, 40, 12, ES_AUTOHSCROLL
    LTEXT      "0 = greedy, higher = more random",        -1, 130, 14, 100, 10

    LTEXT      "Seed:",                                     -1, 12,  32, 60, 10
    EDITTEXT                              IDC_SEED_EDIT,        80, 30, 80, 12, ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON "Random",                  IDC_SEED_RANDOM,     165, 30, 50, 14

    GROUPBOX   "Presets",                                   -1, 12,  52, 218, 56
    PUSHBUTTON "Greedy (t=0)",            IDC_PRESET_GREEDY,    20, 66, 65, 14
    PUSHBUTTON "Balanced (t=0.7)",        IDC_PRESET_BALANCED,  90, 66, 75, 14
    PUSHBUTTON "Creative (t=1.2)",        IDC_PRESET_CREATIVE, 168, 66, 60, 14
    LTEXT      "Greedy is fully deterministic.\nBalanced and Creative add variety with each retry.", -1, 20, 86, 200, 18

    PUSHBUTTON "Reset Defaults",          IDC_DEFAULTS,       12, 135, 70, 18
    DEFPUSHBUTTON "OK",                   IDOK,              130, 135, 45, 18
    PUSHBUTTON    "Cancel",               IDCANCEL,          180, 135, 45, 18
END

IDD_RENAME DIALOGEX 0, 0, 240, 62
CAPTION "Rename Chat"
FONT 8, "MS Shell Dlg"
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
BEGIN
    LTEXT      "Chat title:",                                 -1, 12,  10, 60, 10
    EDITTEXT                              IDC_RENAME_EDIT,        12, 22, 216, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON "OK",                   IDOK,                  130, 42, 45, 14
    PUSHBUTTON    "Cancel",               IDCANCEL,              183, 42, 45, 14
END

1 VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x00040004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "bliss-chat"
      VALUE "FileDescription", "bliss-chat — XP-native LLM chat"
      VALUE "FileVersion", "1.0.0"
      VALUE "InternalName", "XPCHAT"
      VALUE "OriginalFilename", "XPCHAT.EXE"
      VALUE "ProductName", "bliss-chat"
      VALUE "ProductVersion", "1.0.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
