#include <windows.h>

#define IDI_APP 101

IDI_APP ICON "bliss_chat.ico"

1 VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x00040004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "bliss-chat"
      VALUE "FileDescription", "bliss-chat — XP-native LLM chat"
      VALUE "FileVersion", "1.0.0"
      VALUE "InternalName", "XPCHAT"
      VALUE "OriginalFilename", "XPCHAT.EXE"
      VALUE "ProductName", "bliss-chat"
      VALUE "ProductVersion", "1.0.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
